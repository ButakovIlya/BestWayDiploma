COMPOSE_PROJECT_NAME=bestway

# Public VPS settings.
PUBLIC_HOST=your-vps-ip-or-domain
FRONTEND_PORT=3000
BACKEND_HTTP_PORT=80
FLOWER_PORT=5555

# PostgreSQL.
DB__NAME=bestway
DB__USER=bestway
DB__PASSWORD=change_me
DB__PORT=5432
DB__POOL_SIZE=1
DB__MAX_OVERFLOW=20

# Backend application.
APP__TITTLE=BestWay
APP__VERSION=0.1.0
APP__DEBUG=False
APP__BASE_URL=http://your-vps-ip-or-domain
UPTRACE__ENABLED=False
UPTRACE__DSN=
PYTHONPATH=/src/src:/src
UVICORN_WORKERS=4

# Backend auth.
JWT__SECRET_KEY=change_me
JWT__ALGORITHM=HS256

# Celery and Redis.
TASK__APP_NAME=bestway

# SMS provider.
SMS__SERVICE_URL=https://direct.i-dgtl.ru/api/v1/message
SMS__API_KEY=change_me
SMS__CACHE_TIMEOUT=300

# OpenAI / ChatGPT integration.
CHATGPT__SERVICE_URL=https://api.openai.com/v1/chat/completions
CHATGPT__API_KEY=change_me
CHATGPT__MODEL=gpt-5.4-nano
CHATGPT__MAX_RESPONSES_PER_DAY=100
CHATGPT__REQUEST_DELAY=1
CHATGPT__MAX_REQUEST_RETRIES=3

# Optional outbound proxy for ChatGPT requests.
PROXY__HOST=change_me
PROXY__HTTP_PORT=8000
PROXY__SOCKS5_PORT=62567
PROXY__USERNAME=change_me
PROXY__PASSWORD=change_me

# Pusher is used by backend and frontend.
PUSHER__APP_ID=change_me
PUSHER__KEY=change_me
PUSHER__SECRET=change_me
PUSHER__CLUSTER=eu

# Frontend.
NEXT_PUBLIC_BACKEND_API_URL=http://your-vps-ip-or-domain
NEXT_PUBLIC_YANDEX_MAP_KEY=change_me
